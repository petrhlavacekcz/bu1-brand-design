---
interface Props {
  name: string;
  value: string;
  role?: string;
  subtitle?: string;
  text?: 'light' | 'dark';
}
const { name, value, role, subtitle, text = 'dark' } = Astro.props;
const textColor = text === 'light' ? '#fff' : '#141414';
---
<div class="bu1-color-card">
  <div class="bu1-color-chip" style={`background:${value};`}>
    <span class="bu1-color-chip__hex" style={`color:${textColor};`}>{value}</span>
  </div>
  <div class="bu1-color-card__body">
    <p class="bu1-color-card__name">{name}</p>
    {subtitle && <p class="bu1-color-card__meta">{subtitle}</p>}
    {role && <p class="bu1-color-card__role">{role}</p>}
  </div>
</div>
